# Dummy data for elec_pricing.mod — small all-ones values for testing.
# `polyX[x, 2]` is set to 2 (neither 0 nor 1) so the conditional
# `testgeq` / `testeq` constraints don't fire — the model's generated
# `round(polyX[x, 1])` returns a `Float64`, which can't index a Vector.
param S := 2;
param W := 2;
param H := 2;
param X := 2;

param
:    rho     beta    alpha    :=
1    1.0     1.0     1.0
2    1.0     1.0     1.0
;

param
E [*,*,1]
:    1     2    :=
1    1.0   1.0
2    1.0   1.0

 [*,*,2]
:    1     2    :=
1    1.0   1.0
2    1.0   1.0
;

param
:    C     R     :=
1 1  1.0   1.0
1 2  1.0   1.0
2 1  1.0   1.0
2 2  1.0   1.0
;

param polyX :=
1 1 1.0
1 2 2.0
1 3 1.0
1 4 1.0
1 5 1.0
2 1 2.0
2 2 2.0
2 3 1.0
2 4 1.0
2 5 1.0
;
